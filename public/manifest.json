{
  "manifest_version": 3,
  "name": "FormPilot",
  "version": "1.0.0",
  "description": "Production-grade Chrome Extension that eliminates manual form filling at scale.",
  "action": {},
  "options_page": "public/popup.html",
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"]
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/content/network-proxy.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
